<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen>
    <CheckBoxPreference
        key="chainEthereum"
        title="Ethereum"
        defaultValue="true"
        summary="|Ethereum|{@s}"
    />
    <CheckBoxPreference
        key="chainBsc"
        title="BSC (paid API plan)"
        defaultValue="false"
        summary="|BSC|{@s}"
    />
    <CheckBoxPreference
        key="chainArbitrum"
        title="Arbitrum One"
        defaultValue="false"
        summary="|Arbitrum One|{@s}"
    />
    <EditTextPreference
        key="apiKey"
        obligatory="true"
        title="API Key"
        dialogTitle="Etherscan V2 API Key"
        positiveButtonText="OK"
        negativeButtonText="Cancel"
        summary="|API Key|***********"
    />
    <EditTextPreference
        key="account"
        obligatory="true"
        inputType="textPassword"
        title="Wallet address"
        dialogTitle="Wallet address"
        dialogMessage="For multiple addresses, separate them with commas"
        positiveButtonText="OK"
        negativeButtonText="Cancel"
        summary="|Wallet address|{@s}"
    />
    <EditTextPreference
        key="startDate"
        obligatory="true"
        inputType="date"
        title="Load transactions since"
        defaultValue="2018-01-01T00:00:00.000Z"
        dialogTitle="Start date"
        dialogMessage="Enter the date from which to load transactions"
        positiveButtonText="OK"
        negativeButtonText="Cancel"
        summary="|Start date|{@s}"
    />
</PreferenceScreen>
